APP_NAME=Personal AI Assistant
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development
LOG_LEVEL=INFO

# LLM Provider: "fake" or "openai" or "ollama" or "custom"
LLM_PROVIDER=fake

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_TIMEOUT=60

# Ollama Configuration (local models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# System Prompt (customize your assistant's personality)
SYSTEM_PROMPT=You are a helpful personal AI assistant specialized in software development workflows. You are concise, clear, and helpful. You answer in the same language the user writes to you.

# Conversation limits
MAX_CONVERSATION_TOKENS=4096
MAX_CONVERSATION_MESSAGES=50

# Storage: "memory" or "sqlite"
STORAGE_TYPE=sqlite
SQLITE_DB_PATH=data/conversations.db

# Jira Integration
JIRA_ENABLED=false
JIRA_DOMAIN=your-org.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=

# LLM local "llama3.1:8b" or "dolphin-mistral:latest" or "huihui_ai/qwen3-abliterated" or "huihui_ai/dolphin3-abliterated:latest" or "huihui_ai/deepseek-r1-abliterated"
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=huihui_ai/dolphin3-abliterated:latest
